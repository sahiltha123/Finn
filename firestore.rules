rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Finn Core Security: 
    // All financial data is strictly isolated per-user under the /users/{userId} hierarchy.
    // Access is granted only to authenticated users whose UID exactly matches the document path.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default Deny:
    // Any access outside the per-user scope or by unauthenticated users is rejected.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
